{
  "name": "ai-agent-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "turbo dev --parallel",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css}\"",
    "test:e2e": "playwright test",
    "test:load": "node scripts/launch-readiness-load.mjs",
    "report:launch": "node scripts/generate-launch-readiness-report.mjs",
    "db:generate": "pnpm --filter @ai-agent-platform/api db:generate",
    "db:migrate": "pnpm --filter @ai-agent-platform/api db:migrate",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.3",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.1",
    "prisma": "^7.8.0"
  }
}

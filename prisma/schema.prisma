  @@index([organizationId, type, createdAt])
  @@index([referenceType, referenceId])
  @@map("lead_timeline_events")
}

model SupportTicket {
  id              String                @id @default(uuid())
  organizationId  String
  userId          String?
  subject         String
  status          SupportTicketStatus   @default(OPEN)
  priority        SupportTicketPriority @default(NORMAL)
  assignedAdminId String?
  metadata        Json                  @default("{}")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignedAdmin AdminUser?   @relation(fields: [assignedAdminId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([assignedAdminId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@map("support_tickets")
}

model EmailQueue {
  id             String      @id @default(uuid())
  organizationId String
  conversationId String?
  to             String
  subject        String
  body           String      @db.Text
  status         QueueStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([conversationId])
  @@index([status])
  @@index([createdAt])
  @@map("email_queue")
}

model SmsQueue {
  id             String      @id @default(uuid())
  organizationId String
  conversationId String?
  phone          String
  message        String      @db.Text
  status         QueueStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([conversationId])
  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@map("sms_queue")
}

model FaqEntry {
  id              String    @id @default(uuid())
  organizationId  String
  knowledgeBaseId String
  question        String
  answer          String    @db.Text
  status          FaqStatus @default(ACTIVE)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  organization  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase    @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks        KnowledgeChunk[]

  @@index([organizationId])
  @@index([knowledgeBaseId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("faq_entries")
}

model RagSearchEvent {
  id                 String   @id @default(uuid())
  organizationId     String
  knowledgeBaseId    String?
  agentId            String?
  query              String
  source             String
  resultCount        Int
  averageScore       Float
  responseTimeMs     Int
  failed             Boolean  @default(false)
  usedDocumentChunks Int      @default(0)
  usedWebsiteChunks  Int      @default(0)
  usedFaqChunks      Int      @default(0)
  createdAt          DateTime @default(now())

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase? @relation(fields: [knowledgeBaseId], references: [id], onDelete: SetNull)
  agent         Agent?         @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([knowledgeBaseId])
  @@index([agentId])
  @@index([source])
  @@index([failed])
  @@index([createdAt])
  @@map("rag_search_events")
}

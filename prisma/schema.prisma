model Organization {
  id                           String              @id @default(uuid())
  name                         String
  slug                         String              @unique
  plan                         OrganizationPlan    @default(FREE)
  status                       OrganizationStatus  @default(ACTIVE)
  industry                     String?
  companySize                  String?
  provisionStatus              String              @default("PROVISIONED")
  trialStartsAt                DateTime?
  trialEndsAt                  DateTime?
  trialStatus                  TrialStatus?
  personalizedGreetingsEnabled Boolean             @default(true)
  greetingRecencyWindowDays    Int                 @default(90)
  greetingConfidenceThreshold  String              @default("MEDIUM")
  country                      Country             @default(CA)
  countryCode                  String              @default("CA")
  currency                     Currency            @default(CAD)
  timezone                     String              @default("America/Toronto")
  language                     Language            @default(en)
  telephonyProvider            PhoneNumberProvider @default(TWILIO)
  paymentProvider              BillingProvider     @default(STRIPE)
  dateFormat                   String              @default("yyyy-MM-dd")
  timeFormat                   String              @default("HH:mm")
  numberFormat                 String              @default("+1")
  businessHoursTimezone        String              @default("America/Toronto")
  gstNumber                    String?
  billingCompanyName           String?
  billingAddress               Json?
  taxRegion                    String?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  deletedAt                    DateTime?

  members                    OrganizationMember[]
  agents                     Agent[]
  knowledgeBases             KnowledgeBase[]
  documents                  Document[]
  websiteSources             WebsiteSource[]
  websiteContents            WebsiteContent[]
  knowledgeChunks            KnowledgeChunk[]
  knowledgeEmbeddings        KnowledgeEmbedding[]
  faqEntries                 FaqEntry[]
  ragSearchEvents            RagSearchEvent[]
  conversations              Conversation[]
  messages                   Message[]
  conversationMemories       ConversationMemory[]
  memoryFacts                MemoryFact[]
  widgets                    Widget[]
  widgetVisitors             WidgetVisitor[]
  phoneNumbers               PhoneNumber[]
  externalPhoneNumbers       ExternalPhoneNumber[]
  portRequests               PortRequest[]
  portDocuments              PortDocument[]
  customerProfiles           CustomerProfile[]
  customerTimelineEvents     CustomerTimelineEvent[]
  callSummaries              CallSummary[]
  outboundCalls              OutboundCall[]
  campaigns                  Campaign[]
  twilioConnections          TwilioConnection[]
  calls                      Call[]
  callSessions               CallSession[]
  realtimeSessions           RealtimeSession[]
  callRecordings             CallRecording[]
  callTranscripts            CallTranscript[]
  tools                      Tool[]
  toolExecutions             ToolExecution[]
  appointmentRequests        AppointmentRequest[]
  appointments               Appointment[]
  availabilityRules          Availability[]
  contacts                   Contact[]
  leads                      Lead[]
  leadImports                LeadImport[]
  communicationThreads       CommunicationThread[]
  communicationMessages      CommunicationMessage[]
  emailQueue                 EmailQueue[]
  smsQueue                   SmsQueue[]
  invitations                OrganizationInvitation[]
  auditEvents                AuditEvent[]
  leadTimelineEvents         LeadTimelineEvent[]
  billingCustomers           BillingCustomer[]
  subscriptions              Subscription[]
  billingEvents              BillingEvent[]
  billingAddons              BillingAddon[]
  featureOverrides           OrganizationFeatureOverride[]
  usageEvents                UsageEvent[]
  usageCounters              UsageCounter[]
  analyticsEvents            AnalyticsEvent[]
  analyticsDailyMetrics      AnalyticsDailyMetric[]
  analyticsAgentDailyMetrics AnalyticsAgentDailyMetric[]
  analyticsMetricSnapshots   AnalyticsMetricSnapshot[]
  supportTickets             SupportTicket[]
  automationWorkflows        AutomationWorkflow[]
  automationExecutions       AutomationExecution[]
  automationTemplates        AutomationTemplate[]
  workflowTemplates          WorkflowTemplate[]

  @@index([slug])
  @@index([status])
  @@index([country])
  @@index([countryCode])
  @@index([telephonyProvider])
  @@index([paymentProvider])
  @@index([trialStatus, trialEndsAt])
  @@index([deletedAt])
}

model UsageEvent {
  id             String        @id @default(uuid())
  organizationId String
  resourceType   UsageResource
  quantity       Decimal       @db.Decimal(20, 6)
  idempotencyKey String?
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId])
  @@index([resourceType])
  @@index([organizationId, resourceType, createdAt])
  @@map("usage_events")
}

model UsageCounter {
  id                 String        @id @default(uuid())
  organizationId     String
  resourceType       UsageResource
  currentValue       Decimal       @default(0) @db.Decimal(20, 6)
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  version            Int           @default(1)
  updatedAt          DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, resourceType, billingPeriodStart])
  @@index([organizationId])
  @@index([resourceType])
  @@index([billingPeriodStart])
  @@index([organizationId, billingPeriodStart, billingPeriodEnd])
  @@map("usage_counters")
}

model AnalyticsEvent {
  id             String       @id @default(uuid())
  organizationId String
  eventType      String
  idempotencyKey String
  agentId        String?
  metricDate     DateTime
  metadata       Json         @default("{}")
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, metricDate])
  @@index([organizationId, eventType, metricDate])
  @@index([processedAt])
  @@map("analytics_events")
}

model AnalyticsDailyMetric {
  id                     String       @id @default(uuid())
  organizationId         String
  date                   DateTime
  totalCalls             Int          @default(0)
  incomingCalls          Int          @default(0)
  outgoingCalls          Int          @default(0)
  outboundAnsweredCalls  Int          @default(0)
  outboundConversions    Int          @default(0)
  appointments           Int          @default(0)
  appointmentsBookedByAi Int          @default(0)
  leads                  Int          @default(0)
  leadsCreatedByAi       Int          @default(0)
  qualifiedLeads         Int          @default(0)
  customers              Int          @default(0)
  newCustomers           Int          @default(0)
  returningCustomers     Int          @default(0)
  recognizedCallers      Int          @default(0)
  memoryContextLoads     Int          @default(0)
  personalizedGreetings  Int          @default(0)
  greetingLevel0         Int          @default(0)
  greetingLevel1         Int          @default(0)
  greetingLevel2         Int          @default(0)
  greetingLevel3         Int          @default(0)
  repeatCallers          Int          @default(0)
  conversionRate         Decimal      @default(0) @db.Decimal(8, 4)
  customerRetentionRate  Decimal      @default(0) @db.Decimal(8, 4)
  outboundAnswerRate     Decimal      @default(0) @db.Decimal(8, 4)
  outboundConversionRate Decimal      @default(0) @db.Decimal(8, 4)
  followupSuccessRate    Decimal      @default(0) @db.Decimal(8, 4)
  aiMinutes              Decimal      @default(0) @db.Decimal(20, 6)
  aiResponses            Int          @default(0)
  aiInputTokens          BigInt       @default(0)
  aiOutputTokens         BigInt       @default(0)
  toolExecutions         Int          @default(0)
  smsSent                Int          @default(0)
  messagesSent           Int          @default(0)
  revenue                Decimal      @default(0) @db.Decimal(20, 2)
  callDurationSeconds    Int          @default(0)
  avgCallDuration        Decimal      @default(0) @db.Decimal(20, 4)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date])
  @@index([organizationId])
  @@index([date])
  @@index([organizationId, date])
  @@map("analytics_daily_metrics")
}

model AnalyticsAgentDailyMetric {
  id             String       @id @default(uuid())
  organizationId String
  agentId        String
  agentName      String
  date           DateTime
  calls          Int          @default(0)
  appointments   Int          @default(0)
  leads          Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, agentId, date])
  @@index([organizationId, date])
  @@index([organizationId, agentId, date])
  @@map("analytics_agent_daily_metrics")
}

model AnalyticsMetricSnapshot {
  id             String       @id @default(uuid())
  organizationId String
  metricKey      String
  metricValue    Decimal      @db.Decimal(20, 6)
  snapshotDate   DateTime
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, metricKey, snapshotDate])
  @@index([organizationId])
  @@index([metricKey])
  @@index([snapshotDate])
  @@map("analytics_metric_snapshots")
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  status       UserStatus @default(INVITED)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  memberships         OrganizationMember[]
  portDocuments       PortDocument[]           @relation("PortDocumentUploader")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  sentInvitations     OrganizationInvitation[] @relation("OrganizationInvitationInviter")
  auditEvents         AuditEvent[]             @relation("AuditEventActor")
  uploadedDocuments   Document[]               @relation("DocumentUploader")
  supportTickets      SupportTicket[]

  @@index([email])
  @@index([status])
  @@index([deletedAt])
}

model AdminUser {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String
  firstName    String
  lastName     String
  role         AdminRole       @default(SUPER_ADMIN)
  status       AdminUserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  auditLogs       AdminAuditLog[]
  assignedTickets SupportTicket[]

  @@index([email])
  @@index([status])
  @@map("admin_users")
}

model AdminAuditLog {
  id           String   @id @default(uuid())
  adminUserId  String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json     @default("{}")
  ipAddress    String?
  createdAt    DateTime @default(now())

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([action])
  @@index([resourceType])
  @@index([resourceId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  deviceInfo String?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model OrganizationMember {
  id             String     @id @default(uuid())
  organizationId String
  userId         String
  role           MemberRole @default(MEMBER)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@index([deletedAt])
}

model OrganizationInvitation {
  id             String     @id @default(uuid())
  organizationId String
  email          String
  role           MemberRole @default(MEMBER)
  invitedById    String
  acceptedAt     DateTime?
  expiresAt      DateTime
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("OrganizationInvitationInviter", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([email])
  @@index([acceptedAt])
}

model AuditEvent {
  id             String   @id @default(uuid())
  organizationId String
  actorUserId    String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation("AuditEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

model BillingCustomer {
  id                 String          @id @default(uuid())
  organizationId     String
  provider           BillingProvider @default(STRIPE)
  providerCustomerId String
  email              String
  status             String          @default("ACTIVE")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@unique([organizationId, provider])
  @@unique([provider, providerCustomerId])
  @@index([organizationId])
  @@index([providerCustomerId])
  @@index([status])
  @@map("billing_customers")
}

model Subscription {
  id                     String             @id @default(uuid())
  organizationId         String
  billingCustomerId      String
  provider               BillingProvider    @default(STRIPE)
  providerSubscriptionId String
  providerPriceId        String
  plan                   PlanType
  status                 SubscriptionStatus
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  cancelAtPeriodEnd      Boolean            @default(false)

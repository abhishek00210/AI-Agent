{
  "name": "@ai-agent-platform/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "benchmark:latency": "node scripts/benchmark-latency.mjs",
    "benchmark:recording": "node --expose-gc scripts/benchmark-recording-hot-path.cjs",
    "benchmark:usage": "ts-node scripts/benchmark-usage.ts",
    "benchmark:greetings": "ts-node scripts/benchmark-greeting-memory.ts",
    "usage:reconcile": "ts-node scripts/reconcile-usage.ts",
    "analytics:backfill": "ts-node scripts/backfill-analytics.ts",
    "benchmark:analytics": "ts-node scripts/benchmark-analytics.ts",
    "seed:beta": "ts-node scripts/beta-seed.ts",
    "db:generate": "prisma generate --config ../../prisma.config.ts",
    "db:migrate": "prisma migrate dev --config ../../prisma.config.ts",
    "db:validate": "prisma validate --config ../../prisma.config.ts"
  },
  "dependencies": {
    "@ai-agent-platform/shared": "workspace:*",
    "@ai-agent-platform/types": "workspace:*",
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.4",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.4",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.26",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.0.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.78.0",
    "cache-manager": "^6.4.3",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "csv-parse": "^6.2.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "ioredis": "^5.6.1",
    "libphonenumber-js": "^1.13.6",
    "nestjs-pino": "^4.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^22.2.2",
    "ws": "^8.21.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.0.3",
    "prisma": "^7.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
